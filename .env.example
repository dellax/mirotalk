# ====================================================
# MiroTalk SFU v.2.1.73 - Environment Configuration
# ====================================================

# ----------------------------------------------------
# 1. Core System Configuration
# ----------------------------------------------------

NODE_ENV=production
SFU_ANNOUNCED_IP=                                 # SET YOUR SERVER PUBLIC IP
SFU_LISTEN_IP=0.0.0.0
SFU_MIN_PORT=40000
SFU_MAX_PORT=40100
SFU_NUM_WORKERS=
SFU_SERVER=false

# ----------------------------------------------------
# 2. Server Configuration
# ----------------------------------------------------

SERVER_HOST_URL=                                  # SET YOUR DOMAIN (e.g., https://meet.example.com)
SERVER_LISTEN_IP=0.0.0.0
SERVER_LISTEN_PORT=3010
TRUST_PROXY=true
SERVER_SSL_CERT=../ssl/cert.pem
SERVER_SSL_KEY=../ssl/key.pem
CORS_ORIGIN=*

# ----------------------------------------------------
# 3. Logging
# ----------------------------------------------------

LOGS_JSON=false
LOGS_JSON_PRETTY=false

# ----------------------------------------------------
# 4. Media Handling
# ----------------------------------------------------

# Recording
RECORDING_ENABLED=true
RECORDING_DIR='../rec'
RECORDING_MAX_FILE_SIZE=1073741824
RECORDING_UPLOAD_TO_S3=false
RECORDING_ENDPOINT=

# RTMP Streaming (YouTube, Twitch, Facebook, etc.)
RTMP_ENABLED=true
RTMP_DIR='../rtmp'
RTMP_FROM_FILE=true
RTMP_FROM_URL=true
RTMP_FROM_STREAM=true
RTMP_MAX_STREAMS=1
RTMP_USE_NODE_MEDIA_SERVER=true
RTMP_SERVER=rtmp://mirotalk-nms:1935
RTMP_APP_NAME=live
RTMP_STREAM_KEY=
RTMP_SECRET=CHANGE_ME
RTMP_API_SECRET=CHANGE_ME
RTMP_EXPIRATION_HOURS=4
RTMP_ALLOW_CUSTOM_URL=true
RTMP_FFMPEG_PATH=

# ----------------------------------------------------
# 5. Security & Authentication
# ----------------------------------------------------

IP_WHITELIST_ENABLED=false
IP_WHITELIST_ALLOWED=127.0.0.1,::1

JWT_SECRET=CHANGE_ME
JWT_EXPIRATION=1h

OIDC_ENABLED=false
OIDC_ALLOW_ROOMS_CREATION_FOR_AUTH_USERS=true
OIDC_ISSUER=https://server.example.com
OIDC_BASE_URL=
OIDC_CLIENT_ID=clientID
OIDC_CLIENT_SECRET=clientSecret
OIDC_SECRET=CHANGE_ME
OIDC_AUTH_REQUIRED=false
OIDC_AUTH_LOGOUT=true
OIDC_USERNAME_FORCE=true
OIDC_USERNAME_AS_EMAIL=true
OIDC_USERNAME_AS_NAME=false

# Host protection (set to true to require login for room creation)
HOST_PROTECTED=false
HOST_USER_AUTH=false
HOST_USERS="admin:CHANGE_ME:Admin:*"
HOST_MAX_LOGIN_ATTEMPTS=5
HOST_MIN_LOGIN_BLOCK_TIME=15

HOST_USERS_FROM_DB=false
USERS_API_SECRET=CHANGE_ME
USERS_API_ENDPOINT=http://localhost:9000/api/v1/user/isAuth
USERS_ROOM_ALLOWED_ENDPOINT=http://localhost:9000/api/v1/user/isRoomAllowed
USERS_ROOMS_ALLOWED_ENDPOINT=http://localhost:9000/api/v1/user/roomsAllowed
ROOM_EXISTS_ENDPOINT=http://localhost:9000/api/v1/room/exists

PRESENTERS=
PRESENTER_JOIN_FIRST=true

# ----------------------------------------------------
# 6. API Configuration
# ----------------------------------------------------

API_KEY_SECRET=CHANGE_ME
API_ALLOW_STATS=true
API_ALLOW_MEETINGS=false
API_ALLOW_MEETING=true
API_ALLOW_MEETING_END=false
API_ALLOW_JOIN=true
API_ALLOW_TOKEN=false
API_ALLOW_SLACK=false
API_ALLOW_MATTERMOST=false

# ----------------------------------------------------
# 7. Third-Party Integrations (disabled by default)
# ----------------------------------------------------

CHATGPT_ENABLED=false
CHATGPT_BASE_PATH=https://api.openai.com/v1/
CHATGPT_API_KEY=
CHATGPT_MODEL=gpt-3.5-turbo
CHATGPT_MAX_TOKENS=1024
CHATGPT_TEMPERATURE=0.7

DEEP_SEEK_ENABLED=false
DEEP_SEEK_BASE_PATH=https://api.deepseek.com/v1/
DEEP_SEEK_API_KEY=
DEEP_SEEK_MODEL=deepseek-chat
DEEP_SEEK_MAX_TOKENS=1024
DEEP_SEEK_TEMPERATURE=0.7

VIDEOAI_ENABLED=false
VIDEOAI_BASE_PATH=https://api.liveavatar.com
VIDEOAI_API_KEY=
VIDEOAI_MODE=FULL
VIDEOAI_CONTEXT_ID=
VIDEOAI_SYSTEM_LIMIT=
VIDEOAI_SESSION_TIME_LIMIT=

EMAIL_ALERTS_ENABLED=false
EMAIL_NOTIFICATIONS=false
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USERNAME=test
EMAIL_PASSWORD=test
EMAIL_FROM=test@mirotalk.com
EMAIL_SEND_TO=test@mirotalk.com

SLACK_ENABLED=false
SLACK_SIGNING_SECRET=

MATTERMOST_ENABLED=false

DISCORD_ENABLED=false
DISCORD_TOKEN=

NGROK_ENABLED=false
NGROK_AUTH_TOKEN=

SENTRY_ENABLED=false
SENTRY_LOG_LEVELS=error
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

WEBHOOK_ENABLED=false
WEBHOOK_URL=

IP_LOOKUP_ENABLED=false

S3_ENABLED=false
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=mirotalk
S3_REGION=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# ----------------------------------------------------
# 8. UI Customization
# ----------------------------------------------------

BRAND_HTML_INJECTION=true

WIDGET_ENABLED=false
WIDGET_ROOM_ID=support-room
WIDGET_THEME=dark
WIDGET_STATE=minimized
WIDGET_TYPE=support
WIDGET_SUPPORT_POSITION=top-right

UI_LANGUAGE=en
APP_NAME=MiroTalk SFU
APP_TITLE=
APP_DESCRIPTION=
JOIN_DESCRIPTION=
JOIN_BUTTON_LABEL=JOIN ROOM
CUSTOMIZE_BUTTON_LABEL=CUSTOMIZE ROOM
JOIN_LAST_LABEL=Your recent room:

SITE_TITLE=
SITE_ICON_PATH=../images/logo.svg
APPLE_TOUCH_ICON_PATH=../images/logo.svg

# Hide MiroTalk branding
SHOW_TOP_SPONSORS=false
SHOW_FEATURES=false
SHOW_TEAMS=false
SHOW_TRY_EASIER=false
SHOW_POWERED_BY=false
SHOW_SPONSORS=false
SHOW_ADVERTISERS=false
SHOW_SUPPORT_US=false
SHOW_FOOTER=false

# ----------------------------------------------------
# 9. UI Button Configuration
# ----------------------------------------------------

SHOW_ACTIVE_ROOMS=false
SHOW_SHARE_ROOM_POPUP=true
SHOW_SHARE_ROOM_QR_ON_HOVER=true

# Main controls
SHOW_AUDIO_BUTTON=true
SHOW_VIDEO_BUTTON=true
SHOW_SCREEN_BUTTON=true
SHOW_SWAP_CAMERA=true
SHOW_RAISE_HAND=true
SHOW_CHAT_BUTTON=true
SHOW_PARTICIPANTS_BUTTON=true
SHOW_SETTINGS=true
SHOW_EXTRA_BUTTON=true
SHOW_EXIT_BUTTON=true

# Extra buttons
SHOW_SHARE_BUTTON=true
SHOW_HIDE_ME=true
SHOW_FULLSCREEN_BUTTON=true
SHOW_EMOJI=true
SHOW_TRANSCRIPTION=true
SHOW_POLL_BUTTON=true
SHOW_EDITOR_BUTTON=true
SHOW_WHITEBOARD=true
SHOW_DOCUMENT_PIP=true
SHOW_SNAPSHOT=true
SHOW_ABOUT=false

# Settings panel
SHOW_ROOMS=true
ENABLE_FILE_SHARING=true
SHOW_LOCK_ROOM=true
SHOW_UNLOCK_ROOM=true
SHOW_BROADCASTING=true
SHOW_LOBBY=true
SHOW_EMAIL_INVITE=true
SHOW_MIC_OPTIONS=true
SHOW_RTMP_TAB=true
SHOW_NOTIFICATIONS_TAB=true
SHOW_MODERATOR_TAB=true
SHOW_RECORDING_TAB=true
HOST_ONLY_RECORDING=true
ENABLE_PUSH_TO_TALK=true
SHOW_KEYBOARD_SHORTCUTS=true
SHOW_VIRTUAL_BACKGROUND=true

# Video controls
ENABLE_PIP=true
SHOW_MIRROR_BUTTON=true
SHOW_FULLSCREEN=true
SHOW_SNAPSHOT_BUTTON=true
SHOW_MUTE_AUDIO=true
SHOW_PRIVACY_TOGGLE=true
SHOW_VOLUME_CONTROL=true
SHOW_FOCUS_BUTTON=true
SHOW_SEND_MESSAGE=true
SHOW_SEND_FILE=true
SHOW_SEND_VIDEO=true
SHOW_MUTE_VIDEO=true
SHOW_GEO_LOCATION=false
SHOW_BAN_BUTTON=true
SHOW_EJECT_BUTTON=true

# Chat controls
SHOW_CHAT_PIN=true
SHOW_CHAT_MAXIMIZE=true
SHOW_CHAT_SAVE=true
SHOW_CHAT_EMOJI=true
SHOW_CHAT_MARKDOWN=true
SHOW_CHAT_SPEECH=true
ENABLE_CHAT_GPT=false
ENABLE_DEEP_SEEK=false

# Poll controls
SHOW_POLL_PIN=true
SHOW_POLL_MAXIMIZE=true
SHOW_POLL_SAVE=true

# Participants controls
SHOW_SAVE_INFO=true
SHOW_SEND_FILE_ALL=true
SHOW_EJECT_ALL=true

# Whiteboard controls
SHOW_WB_LOCK=true

# ----------------------------------------------------
# 10. Feature Flags
# ----------------------------------------------------

SURVEY_ENABLED=false
SURVEY_URL=

REDIRECT_ENABLED=false
REDIRECT_URL=

# Disable analytics
STATS_ENABLED=false
STATS_SRC=
STATS_ID=

CUSTOM_NOISE_SUPPRESSION_ENABLED=true

# ----------------------------------------------------
# 11. Global Moderation
# ----------------------------------------------------

ROOM_MAX_PARTICIPANTS=100
ROOM_LOBBY=false

# ----------------------------------------------------
# 12. Mediasoup Configuration
# ----------------------------------------------------

MEDIASOUP_ROUTER_AUDIO_LEVEL_OBSERVER_ENABLED=true
MEDIASOUP_ROUTER_ACTIVE_SPEAKER_OBSERVER_ENABLED=false
MEDIASOUP_LOG_LEVEL=error
